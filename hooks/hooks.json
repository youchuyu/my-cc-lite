{
  "description": "my-cc-lite state-backed orchestration hooks",
  "hooks": {
    "UserPromptExpansion": [
      {
        "matcher": "^my-cc-lite:(init|plan|do|verify|archive)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/stage-preflight.mjs\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/stage-context.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "^my-cc-lite:executor$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/do-agent-chain.mjs\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "^my-cc-lite:verifier$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/do-agent-chain.mjs\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "^my-cc-lite:debugger$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/do-agent-chain.mjs\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "^my-cc-lite:task-materializer$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/do-agent-chain.mjs\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
